# Copy to .env.local and fill in. Used only by server-side route handlers.

# Claude vision (chart analysis + chat)
ANTHROPIC_API_KEY=sk-ant-...

# S3 persistence (Save)
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET_NAME=your-bucket

# Cognito auth (login + TOTP 2FA)
COGNITO_REGION=eu-west-1
COGNITO_USER_POOL_ID=...
COGNITO_CLIENT_ID=...
COGNITO_CLIENT_SECRET=...

# Session cookie encryption — any 32+ byte random string (e.g. `openssl rand -base64 32`)
SESSION_SECRET=...
